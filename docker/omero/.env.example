# ---- ImSwitch <-> OMERO bridge configuration ----
# Copy this file to ".env" in the same folder, then adjust:
#     cp .env.example .env
# Both `docker compose` and watcher.py read it. (Compose reads .env automatically;
# watcher.py loads it from its own folder.)

# Host folder where ImSwitch writes acquisitions = the production DATA_PATH from
# ../docker-compose.yml. It is bind-mounted into the OMERO server at the SAME path,
# and watcher.py watches it on the host. Change this if your data lives elsewhere
# (e.g. an external SSD under /media/... ).
IMSWITCH_DATA_DIR=/home/pi/Datasets

# OMERO admin ("root") password. Used both for the web UI login and by watcher.py
# to authenticate imports. CHANGE THIS before exposing the Pi to a shared network.
OMERO_ROOT_PASS=omero

# PostgreSQL credentials (internal to the stack; not exposed on the network).
OMERO_DB_NAME=omero
OMERO_DB_USER=omero
OMERO_DB_PASS=omero

# Web UI port -> browse at http://<pi-ip>:<port>
OMERO_WEB_PORT=4080

# Container names + image references (multi-arch: linux/amd64 + linux/arm64).
# Pin to a versioned tag (e.g. ...:5.6.9-0-ubuntu2204) once you settle on a version.
OMERO_SERVER_CONTAINER=omero-server
OMERO_WEB_CONTAINER=omero-web
OMERO_SERVER_IMAGE=ghcr.io/manics/omero-server-docker:ubuntu
OMERO_WEB_IMAGE=ghcr.io/manics/omero-web-docker:ubuntu

# Path to the `omero` CLI INSIDE the server container. Leave blank to auto-detect
# (the CLI lives in a venv that isn't on docker-exec's PATH). Only set this if
# auto-detection fails -- find it with:
#   docker exec omero-server bash -lc 'command -v omero'
# (manics/ome images: usually /opt/omero/server/venv3/bin/omero)
OMERO_BIN=

# ---- watcher.py tuning (host-side importer) ----
# Seconds a file / .zarr store must stop changing before it is considered finished
# and imported. Raise it for long multi-GB acquisitions on slow disks.
OMERO_IMPORT_STABLE_SECONDS=20
# How often (seconds) to rescan the data tree.
OMERO_IMPORT_POLL_SECONDS=10
# Transfer mode:
#   ln_s = in-place symlink import (NO copy; OMERO references the ImSwitch file).
#          Best on a storage-constrained Pi. Files must stay where ImSwitch wrote them.
#   cp   = copy bytes into OMERO's managed repository (data duplicated, fully detached).
OMERO_IMPORT_TRANSFER=ln_s
# Attempt OME-Zarr / NGFF import. Best-effort: OME-TIFF is the reliable path; zarr
# import depends on the Bio-Formats version bundled in the server image.
OMERO_IMPORT_ZARR=true
# When a folder holds a "primary" output (*.ome.tif/*.ome.tiff/*.h5 or a *.zarr store),
# skip the loose per-tile *.tif files written next to it so OMERO isn't flooded with
# hundreds of tiles. Set false to import every individual tile as its own image.
OMERO_IMPORT_SKIP_TILE_TIFFS=true
# OMERO Project that all ImSwitch datasets are grouped under in the web UI.
OMERO_IMPORT_PROJECT=ImSwitch
